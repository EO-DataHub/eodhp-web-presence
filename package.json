{
  "name": "eodhp-web-presence",
  "version": "0.1.19",
  "description": "Web presence for EODHP",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "preserve": "npm run build:icons",
    "serve": "webpack serve --config webpack.config.js --mode development",
    "prebuild": "npm run build:icons",
    "build": "webpack --config webpack.config.js --mode production",
    "lint": "biome check assets scripts",
    "lint:fix": "biome check --write assets scripts",
    "lint:css": "stylelint 'assets/**/*.{css,scss}'",
    "lint:css:fix": "stylelint 'assets/**/*.{css,scss}' --fix",
    "predev": "npm run build:icons",
    "dev": "webpack --config webpack.config.js --mode development",
    "predev-watch": "npm run build:icons",
    "dev-watch": "webpack --config webpack.config.js --mode development --watch",
    "build:icons": "node scripts/build_mdi_icons.mjs eodhp_web_presence/dist/mdi_icons.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "jquery": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@biomejs/biome": "2.5.1",
    "@mdi/svg": "^7.4.47",
    "babel-loader": "10.1.1",
    "css-loader": "7.1.4",
    "prettier": "3.8.4",
    "sass": "1.98.0",
    "sass-loader": "17.0.0",
    "style-loader": "4.0.0",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-prettier": "5.0.3",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  }
